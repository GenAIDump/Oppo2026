# File: Oppo/.env.example
# Purpose: Example environment variables for Oppo v0.1 (LLM/MCP). Copy to .env and fill in values.

# --- Neo4j Database Connection ---
NEO4J_URI="neo4j://neo4j:7687"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="password_change_this" # Set your secure Neo4j password
# Optional: Ports if changed from default in docker-compose
# NEO4J_BROWSER_PORT=7474
# NEO4J_BOLT_PORT=7687

# --- JWT Authentication (for A2A Host user access) ---
# Generate a strong random key! Use: openssl rand -hex 32
SECRET_KEY="replace_with_a_strong_random_secret_key_using_openssl_rand"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="60"

# --- Listener API Keys (REQUIRED for listeners) ---
YOUTUBE_API_KEY="YOUR_YOUTUBE_DATA_API_V3_KEY_HERE" # From Google Cloud Console
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN_HERE"   # From @BotFather on Telegram

# --- LLM API Keys (Add keys ONLY for the providers you intend to use) ---
GOOGLE_API_KEY="YOUR_GOOGLE_API_KEY_FOR_GEMINI_HERE" # From Google AI Studio or Cloud Console (Enable Generative Language API)
# OPENAI_API_KEY="YOUR_OPENAI_API_KEY_HERE"
# ANTHROPIC_API_KEY="YOUR_ANTHROPIC_API_KEY_HERE"

# --- LLM Configuration (Select provider/model for tasks) ---
# Valid Options: "GEMINI", "OPENAI", "ANTHROPIC" (must match llm_interface.py implementation)
CONTRADICTION_LLM_PROVIDER="GEMINI"
DISINFO_LLM_PROVIDER="GEMINI"
FACTCHECK_LLM_PROVIDER="GEMINI"
EVASION_LLM_PROVIDER="GEMINI"
# Optional: Specify models if needed (defaults can be set in llm_interface.py)
GEMINI_MODEL_NAME="gemini-1.5-flash-latest" # Example, use appropriate model
# OPENAI_MODEL_NAME="gpt-4o"
# ANTHROPIC_MODEL_NAME="claude-3-haiku-20240307"

# --- Optional: Background Data Collection API Keys ---
# FEC_API_KEY=""
# OPENSECRETS_API_KEY=""

# --- Host & MCP Configuration ---
# URLs below are examples for Docker Compose internal networking. Adjust if needed.
A2A_HOST_URL="http://localhost:8000"            # External URL A2A agents might use
A2A_HOST_INTERNAL_URL="http://a2a_host:8000"    # Internal URL for service-to-service
MCP_SERVER_URL="http://mcp_server:8001"       # Internal URL for MCP Service
LOG_LEVEL="INFO"                                # DEBUG, INFO, WARNING, ERROR, CRITICAL

# --- Internal Service API Key ---
# Generate a strong random key! Use: openssl rand -hex 32
# Used by services (listener, analysis) to authenticate with MCP/Ingestion endpoints
INTERNAL_SERVICE_API_KEY="replace_with_internal_service_api_key_for_securing_endpoints"

# --- Optional: A2A Agent Secrets (Load dynamically/securely in production!) ---
# Used by A2A Host Distribution to sign outgoing messages
# Example only - DO NOT commit real secrets to Git
# AGENT_1_ENDPOINT="https://campaign1.example.com/a2a/receive"
# AGENT_1_SECRET="secret_for_campaign_1"
# AGENT_2_ENDPOINT="https://campaign2.example.com/a2a/receive"
# AGENT_2_SECRET="secret_for_campaign_2"
